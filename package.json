{
	"name": "SpyOn",
	"description": "A simple offline Spyfall-style party game for passing around a single device",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/H6LS1S/spyon"
	},
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
		"lint": "",
		"format": "prettier --write .",
		"prepare": "husky",
		"postinstall": "sv-router"
	},
	"dependencies": {
		"@fontsource-variable/martian-mono": "^5.2.7",
		"lucide-svelte": "^1.0.1",
		"sv-router": "^0.15.0",
		"sveltejs-typestore": "^1.0.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-angular": "^20.5.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/vite": "^4.2.2",
		"@tsconfig/svelte": "^5.0.5",
		"@types/node": "^24.6.2",
		"@vite-pwa/assets-generator": "^1.0.2",
		"husky": "^9.1.7",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.39.9",
		"svelte-check": "^4.3.2",
		"tailwindcss": "^4.2.2",
		"typescript": "~5.9.3",
		"vite": "^7.1.9",
		"vite-plugin-pwa": "^1.1.0",
		"workbox-window": "^7.4.0"
	},
	"overrides": {
		"sharp": "^0.33.5",
		"sharp-ico": "^0.1.5"
	},
	"release": {
		"branches": [
			"main"
		],
		"plugins": [
			"@semantic-release/commit-analyzer",
			"@semantic-release/release-notes-generator",
			"@semantic-release/changelog",
			[
				"@semantic-release/npm",
				{
					"npmPublish": false
				}
			],
			[
				"@semantic-release/git",
				{
					"assets": [
						"package.json",
						"package-lock.json",
						"CHANGELOG.md"
					],
					"message": "chore(release): ${nextRelease.version} [skip ci]"
				}
			],
			"@semantic-release/github"
		]
	}
}
